{
  "name": "bookmarks-ai-extension",
  "version": "1.0.0",
  "description": "AI-powered Chrome bookmark organizer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run fix:manifest",
    "fix:manifest": "node scripts/fix-manifest.js",
    "preview": "vite preview",
    "test": "node --experimental-strip-types --test \"scripts/*.test.ts\"",
    "test:cleanup": "node --experimental-strip-types --test scripts/cleanup-service.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
